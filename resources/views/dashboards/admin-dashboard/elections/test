<script>
    function electionForm() {
        return {
            currentStep: 1,
            steps: [
                { id: 1, title: 'Details' },
                { id: 2, title: 'Eligibility' },
                { id: 3, title: 'Positions' },
                { id: 4, title: 'Candidates' }
            ],
            formData: {
                title: '',
                bio: '',
                start_at: '',
                end_at: '',
                eligibilityType: 'all', 
                positions: [] 
            },
            newPosition: {
                title: '',
                max_selection: 1
            },
            newCandidate: {
                positionIndex: '',
                name: '',
                grade_level_id: '',
                section_id: '',
                bio: '',
                party: '',
                platform: '',
                photo_path: ''
            },

            validateDates() {
                // IMPROVEMENT: Use the Alpine data directly instead of querySelector
                const start = this.formData.start_at;
                const end = this.formData.end_at;

                if (start && end) {
                    if (new Date(end) <= new Date(start)) {
                        alert('End Date must be later than the Start Date.');
                        return false; // Validation failed
                    }
                }
                return true; // Validation passed
            },
            
            nextStep() {
                if(this.currentStep === 1) {
                    // 1. Check if empty
                    if(!this.formData.title || !this.formData.start_at || !this.formData.end_at) {
                        alert('Please fill in all required fields.');
                        return;
                    }

                    // 2. FIX IS HERE: Call the validation function
                    if(!this.validateDates()) {
                        return; // Stop if dates are invalid
                    }
                }

                if(this.currentStep === 3 && this.formData.positions.length === 0) {
                    alert('Please add at least one position.');
                    return;
                }
                
                this.currentStep++;
            },

            addPosition() {
                if(!this.newPosition.title) return;
                
                this.formData.positions.push({
                    title: this.newPosition.title,
                    max_selection: this.newPosition.max_selection,
                    candidates: [] 
                });

                this.newPosition.title = '';
                this.newPosition.max_selection = 1;
            },

            removePosition(index) {
                this.formData.positions.splice(index, 1);
            },

            addCandidate() {
                if(this.newCandidate.positionIndex === '' || !this.newCandidate.name) return;

                const posIndex = this.newCandidate.positionIndex;

                this.formData.positions[posIndex].candidates.push({
                    name: this.newCandidate.name,
                    grade_level_id: this.newCandidate.grade_level_id,
                    section_id: this.newCandidate.section_id,
                    bio: this.newCandidate.bio,
                    party: this.newCandidate.party,
                    platform: this.newCandidate.platform,
                    photo_path: this.newCandidate.photo_path,
                });

                this.newCandidate = {
                    positionIndex: '',
                    name: '',
                    grade_level_id: '',
                    section_id: '',
                    bio: '',
                    party: '',
                    platform: '',
                    photo_path: ''
                };
            },

            handlePhoto(event) {
                const file = event.target.files[0];
                if (file) {
                    this.newCandidate.photo_path = file.name; 
                }
            },


            removeCandidate(posIndex, candIndex) {
                this.formData.positions[posIndex].candidates.splice(candIndex, 1);
            }
        }
    }
</script>
